rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Worship Songs Collection Rules
    match /worship_songs/{songId} {
      // Publicly viewable and manageable since the platform is designed as a collaborative, local-first hybrid prompter
      allow read: if true;
      allow delete: if true;
      
      // Enforce type validation and size limits on create and updates
      allow create, update: if isValidWorshipSong(request.resource.data);
    }

    // 3. System Live Session singleton Rules
    match /system/live_session {
      allow read, write: if true;
    }

    // 4. Scheduled Worships Rules
    match /scheduled_worships/{worshipId} {
      allow read, delete: if true;
      allow create, update: if isValidScheduledWorship(request.resource.data);
    }
  }

  // Strong validation schema representing the properties of a ScheduledWorship
  function isValidScheduledWorship(data) {
    return data.title is string
        && data.title.size() <= 128
        && (!('description' in data) || (data.description is string && data.description.size() <= 512))
        && data.songId is string
        && data.songId.size() <= 128
        && data.startTime is number
        && data.hostId is string
        && data.hostId.size() <= 128
        && data.createdAt is number;
  }

  // Strong validation schema representing the properties of a WorshipSong
  function isValidWorshipSong(data) {
    return data.title is string 
        && data.title.size() <= 128
        && (!('id' in data) || (data.id is string && data.id.size() <= 128))
        && (!('artist' in data) || (data.artist is string && data.artist.size() <= 128))
        && (!('key' in data) || (data.key is string && data.key.size() <= 32))
        && (!('tempo' in data) || data.tempo is number)
        && (!('audioUrl' in data) || (data.audioUrl is string && data.audioUrl.size() <= 2048))
        && (!('audioFileName' in data) || (data.audioFileName is string && data.audioFileName.size() <= 256))
        && (!('isPreloaded' in data) || data.isPreloaded is bool)
        && (!('lyrics' in data) || data.lyrics is list)
        && (!('lines' in data) || data.lines is list)
        && (!('musicSpeed' in data) || data.musicSpeed is number)
        && (!('updatedAt' in data) || data.updatedAt is number);
  }

  // Strong validation schema representing the properties of a LiveSession
  function isValidLiveSession(data) {
    return (!('activeSongId' in data) || (data.activeSongId == null || data.activeSongId is string))
        && data.status is string
        && (data.status == 'playing' || data.status == 'paused' || data.status == 'idle')
        && data.eventTimestamp is number
        && data.playbackPosition is number;
  }
}
